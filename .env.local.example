# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI Gateway — use OIDC auth (vercel env pull provisions VERCEL_OIDC_TOKEN automatically)
# For non-Vercel environments, set AI_GATEWAY_API_KEY instead:
# AI_GATEWAY_API_KEY=your-gateway-key

# Widget (allowed origin for CORS)
ALLOWED_ORIGIN=https://elevateetiquette.com
